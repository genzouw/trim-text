root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.go]
indent_size = 4

[*.php]
indent_size = 4

[*.py]
indent_size = 4

[*.java]
indent_size = 4
